# Environment variables for local development
# Copy this file to .env and modify as needed
#
# Usage:
#   cp .env.example .env
#   make dev  # This will run setup and create VIKUNJA_TOKEN automatically
#   - OR -
#   make setup-user  # Just run the user setup

# Vikunja Configuration
# URL of the Vikunja instance (use vikunja:3456 when running via docker-compose)
VIKUNJA_HOST=http://vikunja:3456

# API token for Vikunja authentication
# Generated automatically by make setup-user (via scripts/setup-vikunja.sh)
# DO NOT commit real tokens to version control
VIKUNJA_TOKEN=

# Allow insecure TLS connections (useful for local development)
VIKUNJA_INSECURE=true

# Development user credentials (used by scripts/setup-vikunja.sh)
# These are used to auto-create a user and generate an API token
VIKUNJA_EMAIL=admin@example.com
VIKUNJA_PASSWORD=admin123
VIKUNJA_USERNAME=admin

# MCP Server Configuration
# Transport type: http or stdio
MCP_TRANSPORT=http

# HTTP transport settings
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080
MCP_HTTP_SESSION_TIMEOUT=1h
MCP_HTTP_STATELESS=false

# Output Format
# Options: markdown, json, plain
VIKUNJA_OUTPUT_FORMAT=markdown

# Development Settings
DEBUG=true
LOG_LEVEL=debug

# Test Settings (for mcp-vikunja-test service)
TEST_RUNNER_PORT=8081
TEST_STATELESS=true